# Ejemplo de archivo de configuración de entorno para SRI_Project
# Copia este archivo como `.env` y rellena los valores según tu entorno.

# --------------------------------------------------
# Configuración de ElasticSearch
# --------------------------------------------------
# URL(s) de tus nodos de ElasticSearch (pueden ser múltiples, separadas por comas).
# - En desarrollo local con Docker suele ser: https://localhost:9200
# - Si usas un cluster, puedes incluir varios hosts.
ELASTICSEARCH_HOSTS="https://localhost:9200"

# Usuario y contraseña para autenticar contra ElasticSearch.
# Asegúrate de que el usuario exista y tenga permisos para crear índices y escribir.
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=TU_PASSWORD_AQUI

# Nombre del índice donde se almacenarán los documentos.
# Cambia esto si deseas tener varios índices (por ejemplo: scraped-docs-v2).
INDEX_NAME=scraped-docs

